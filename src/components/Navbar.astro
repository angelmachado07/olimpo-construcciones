  <nav class="navbar">
  <div class="container navbar-inner">
    <a href="#inicio" class="logo" aria-label="Ir al inicio">
  <img src="/brand/Logo.png" alt="Olimpo Construcciones" class="logo-img" />
  <span class="logo-text"></span>
</a>

    <button
      class="menu-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      type="button"
    >
      ☰
    </button>

    <ul class="nav-links">
      <li><a href="#inicio">Inicio</a></li>
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#trabajos">Trabajos</a></li>
      <li><a href="#equipo">Equipo</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
  </div>
</nav>

<script>
    // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.querySelector(".menu-toggle");
    const links = document.querySelector(".nav-links");
    const nav = document.querySelector(".navbar");

    if (!(button instanceof HTMLButtonElement)) return;
    if (!(links instanceof HTMLElement)) return;
    if (!(nav instanceof HTMLElement)) return;

    const closeMenu = () => {
      links.classList.remove("open");
      button.setAttribute("aria-expanded", "false");
    };

    const toggleMenu = () => {
      const isOpen = links.classList.toggle("open");
      button.setAttribute("aria-expanded", String(isOpen));
    };

    button.addEventListener("click", toggleMenu);

    links.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", closeMenu);
    });

    document.addEventListener("click", (e) => {
      if (!links.classList.contains("open")) return;
      const target = e.target;
      if (!(target instanceof Node)) return;
      if (!nav.contains(target)) closeMenu();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) closeMenu();
    });

    // Active link por sección visible
    const sectionIds = ["inicio", "servicios", "trabajos", "equipo", "ubicacion", "contacto"];
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter((el) => el instanceof HTMLElement);

    const navAnchors = Array.from(links.querySelectorAll("a"));

    const setActive = (sectionId) => {
      navAnchors.forEach((a) => a.classList.remove("active"));
      const current = navAnchors.find((a) => a.getAttribute("href") === `#${sectionId}`);
      if (current) current.classList.add("active");
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // Nos quedamos con la última sección que entra a la zona activa
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.target instanceof HTMLElement) {
            setActive(entry.target.id);
          }
        });
      },
      {
        root: null,
        // zona activa: un poco debajo del navbar
        rootMargin: "-70px 0px -70% 0px",
        threshold: 0,
      }
    );

    sections.forEach((s) => observer.observe(s));
    setActive("inicio");
  });
</script>