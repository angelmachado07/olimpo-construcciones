---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

const {
  title = "Olimpo Construcciones",
  description = "Construcción y reformas en Piriápolis, Maldonado.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title} | Construcción y reformas en Piriápolis</title>
    <meta name="description" content="Olimpo Construcciones realiza construcción de casas, reformas y ampliaciones en Piriápolis y Maldonado. Atención directa por WhatsApp." />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Olimpo Construcciones | Construcción y reformas en Piriápolis" />
    <meta property="og:description" content="Olimpo Construcciones realiza construcción de casas, reformas y ampliaciones en Piriápolis y Maldonado. Atención directa por WhatsApp." />
    <meta property="og:image" content="/hero/hero.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Navbar />
    <slot />
  </body>
</html>