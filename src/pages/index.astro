---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Olimpo Construcciones"
  description="Construcción, reformas y ampliaciones en Piriápolis, Maldonado."
>
  <main>
    <!-- INICIO / HERO -->
    <section id="inicio" class="hero">
      <div class="container">
        <!-- <p class="hero-kicker animate-in delay-1">Olimpo Construcciones</p> -->

        <h1 class="animate-in delay-1">Espacios bien construidos, pensados para durar.</h1>

        <p class="section-lead animate-in delay-2">
          En Olimpo Construcciones realizamos obras residenciales, reformas y
          ampliaciones con foco en prolijidad, orden y seguimiento cercano en
          cada etapa del trabajo.
        </p>

        <div class="hero-actions animate-in delay-3">
          <a
            class="btn btn-primary"
            href="https://wa.me/59892560186?text=Hola,%20quiero%20consultar%20por%20una%20obra."
            target="_blank"
            rel="noopener"
          >
            Solicitar presupuesto
          </a>
          <a class="btn btn-ghost" href="#trabajos">
            Ver trabajos
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="margin-left:8px"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- BLOQUE DE CONFIANZA -->
    <section class="trust-strip">
      <div class="container trust-grid">
        <!--div class="trust-brand-wrapper scroll-fade-in delay-1">
          <img
            src="/brand/Logo.png"
            alt="Olimpo Construcciones"
            class="trust-logo"
            loading="lazy"
          />
        </div-->

        <article class="scroll-fade-in">
          <strong>Trato directo</strong>
          <p>Comunicación clara desde el primer contacto hasta la entrega.</p>
        </article>

        <article class="scroll-fade-in delay-1">
          <strong>Orden en cada etapa</strong>
          <p>Planificación, seguimiento y cuidado de detalles durante la obra.</p>
        </article>

        <article class="scroll-fade-in delay-2">
          <strong>Terminaciones prolijas</strong>
          <p>Buscamos resultados sólidos, funcionales y bien resueltos.</p>
        </article>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="section section-alt">
