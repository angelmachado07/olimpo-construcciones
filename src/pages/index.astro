---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Olimpo Construcciones"
  description="Construcción, reformas y ampliaciones en Piriápolis, Maldonado."
>
  <main>
    <!-- INICIO / HERO WOW -->
    <section id="inicio" class="hero">
      <div class="container">
        <div class="hero-badge">
          <span class="dot"></span>
          Piriápolis · Maldonado · Obras residenciales
        </div>

        <h1>Olimpo Construcciones</h1>
        <p class="section-lead">
          Construcción, reformas y ampliaciones con terminaciones prolijas,
          comunicación clara y seguimiento cercano.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="#contacto">Contactar</a>
          <a class="btn btn-ghost" href="#trabajos">Ver trabajos</a>
        </div>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="section section-alt">
      <div class="container">
        <h2 class="section-title">Servicios</h2>
        <p class="section-lead">
          Soluciones prácticas y funcionales, desde obra nueva hasta mantenimiento.
        </p>

        <div class="grid">
          <article class="card">
            <h3>Construcción de casas</h3>
            <p>Obra nueva, desde base hasta terminaciones.</p>
          </article>

          <article class="card">
            <h3>Reformas</h3>
            <p>Cocina, baño, pintura, electricidad y más.</p>
          </article>

          <article class="card">
            <h3>Ampliaciones</h3>
            <p>Metros nuevos integrados a tu casa actual.</p>
          </article>

          <article class="card">
            <h3>Cabañas</h3>
            <p>Soluciones prácticas y funcionales.</p>
          </article>

          <article class="card">
            <h3>Obras varias</h3>
            <p>Muros, cercas, pisos, veredas y arreglos.</p>
          </article>

          <article class="card">
            <h3>Mantenimiento</h3>
            <p>Pequeñas reparaciones y ajustes.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- TRABAJOS -->
    <section id="trabajos" class="section">
      <div class="container">
        <h2 class="section-title">Trabajos realizados</h2>
        <p class="section-lead">
          Algunas obras y procesos. Más trabajos disponibles en redes y por consulta.
        </p>

        <div class="works-grid">
          <figure class="work-card">
            <img src="/works/obra-1.jpg" alt="Trabajo realizado 1" loading="lazy" />
          </figure>
          <figure class="work-card">
            <img src="/works/obra-2.jpg" alt="Trabajo realizado 2" loading="lazy" />
          </figure>
          <figure class="work-card">
            <img src="/works/obra-3.jpg" alt="Trabajo realizado 3" loading="lazy" />
          </figure>
          <figure class="work-card">
            <img src="/works/obra-4.jpg" alt="Trabajo realizado 4" loading="lazy" />
          </figure>
          <figure class="work-card">
            <img src="/works/obra-5.jpg" alt="Trabajo realizado 5" loading="lazy" />
          </figure>
          <figure class="work-card">
            <img src="/works/obra-6.jpg" alt="Trabajo realizado 6" loading="lazy" />
          </figure>
        </div>
      </div>
    </section>

    <!-- EQUIPO -->
    <section id="equipo" class="section section-alt">
      <div class="container">
        <h2 class="section-title">Equipo</h2>
        <p class="section-lead">
          Trabajo serio, comunicación clara y foco en terminaciones.
        </p>

        <div class="card">
          <h3>Coordinación y cumplimiento</h3>
          <p>
            Organizamos el trabajo por etapas, cuidando tiempos, materiales y detalles
            para llegar a un resultado prolijo.
          </p>
        </div>
      </div>
    </section>

    <!-- UBICACIÓN -->
    <section id="ubicacion" class="section">
      <div class="container">
        <h2 class="section-title">Ubicación</h2>
        <p class="section-lead">
          Por ahora trabajamos en Piriápolis y Maldonado. (Luego definimos ubicación/oficina)
        </p>

        <div class="map-placeholder">Zona Piriápolis / Maldonado</div>
      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contacto" class="section section-alt">
      <div class="container">
        <h2 class="section-title">Contacto</h2>
        <p class="section-lead">
          WhatsApp como canal principal. Teléfono y email como alternativas.
        </p>

        <div class="contact-actions">
          <!-- CAMBIAR EL NUMERO DE WHATSAPP POR EL DEL CLIENTE ANTES DE PRODUCCIÓN -->
          <a
            class="btn btn-primary"
            href="https://wa.me/59899523024?text=Hola,%20quiero%20consultar%20por%20una%20obra."
            target="_blank"
            rel="noopener"
          >
            WhatsApp
          </a>
          <a class="btn btn-ghost" href="#">Email</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="container">
        <p>
          © {new Date().getFullYear()} Olimpo Construcciones — Piriápolis, Maldonado
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>