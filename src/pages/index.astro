  <!-- Lightbox -->
  <div id="lightbox" class="lightbox">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" aria-label="Cerrar">&times;</button>
      <img id="lightbox-img" src="" alt="Olimpo Construcciones" />
      <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    document.addEventListener("DOMContentLoaded", () => {
      const scrollObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            scrollObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document
        .querySelectorAll(
          ".trust-grid article, .service-card, .process-card, .section-title, .work-card, .contact-box"
        )
        .forEach((el) => {
          el.classList.add("scroll-fade-in");
          scrollObserver.observe(el);
        });

      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const lightboxCaption = document.getElementById("lightbox-caption");
      const closeBtn = document.querySelector(".lightbox-close");

      const openLightbox = (src, caption = "") => {
        lightboxImg.src = src;
        if (lightboxCaption) lightboxCaption.textContent = caption;
        lightbox.classList.add("open");
      };

      const closeLightbox = () => {
        lightbox.classList.remove("open");
        setTimeout(() => {
          if (!lightbox.classList.contains("open")) {
             lightboxImg.src = "";
             if (lightboxCaption) lightboxCaption.textContent = "";
          }
        }, 300);
      };

      document.querySelectorAll(".work-card img").forEach((img) => {
        img.closest(".work-card").addEventListener("click", () => {
          const title = img.closest(".work-card").querySelector(".work-tag")?.textContent || "";
          openLightbox(img.src, title);
        });
      });

      const logoLink = document.querySelector(".logo");
      if (logoLink) {
        logoLink.addEventListener("click", (e) => {
          if (window.scrollY < 200) {
            e.preventDefault();
            openLightbox(logoLink.querySelector("img").src, "Olimpo Construcciones");
          }
        });
      }

      closeBtn?.addEventListener("click", closeLightbox);
      lightbox?.querySelector(".lightbox-overlay")?.addEventListener("click", closeLightbox);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeLightbox();
      });
    });
  </script>
</BaseLayout>